#!/usr/bin/env bash

# toggle nix daemon proxy

NIX_DAEMON_DIR=/run/systemd/system/nix-daemon.service.d
OVERRIDE="$NIX_DAEMON_DIR/override.conf"

if [ -f "$OVERRIDE" ]; then
  sudo rm "$OVERRIDE"
  echo "(nix) OFF"
else
  if [ -z "${PROXYADDRESS:-}" ]; then
    echo "ERROR: \$PROXYADDRESS is not set" >&2
    exit 1
  fi
  sudo mkdir -p "$NIX_DAEMON_DIR"
  sudo tee "$OVERRIDE" > /dev/null <<-EOF
[Service]
Environment="http_proxy=$PROXYADDRESS"
Environment="https_proxy=$PROXYADDRESS"
Environment="HTTP_PROXY=$PROXYADDRESS"
Environment="HTTPS_PROXY=$PROXYADDRESS"
Environment="all_proxy=$PROXYADDRESS"
EOF
  echo "(nix) ON @ $PROXYADDRESS"
fi

sudo systemctl daemon-reload
sudo systemctl restart nix-daemon

